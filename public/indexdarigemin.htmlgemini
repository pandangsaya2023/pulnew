<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PULNEW - Portal Info Terkini</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --jarak-utama: 12px; --warna-merah: #d32f2f; --warna-biru: #1a237e; --warna-bg: #f4f6f9; }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif; }
        body { background: var(--warna-bg); }
        .header-container { background: white; padding: 12px 20px; border-bottom: 3px solid var(--warna-merah); position: sticky; top: 0; z-index: 100; }
        .logo-bar { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
        .logo-text { font-size: 24px; font-weight: 800; color: var(--warna-biru); font-family: 'Poppins'; }
        .logo-new { color: var(--warna-merah); }
        .container { max-width: 1100px; margin: 0 auto; padding: 10px; }
        .news-hero { display: block; border-radius: 12px; overflow: hidden; margin-bottom: 12px; position: relative; }
        .news-hero img { width: 100%; height: 240px; object-fit: cover; }
        .hero-content { position: absolute; bottom: 0; width: 100%; padding: 20px; background: linear-gradient(transparent, rgba(0,0,0,0.9)); color: white; }
        .badge { display: inline-block; padding: 3px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; background: var(--warna-merah); color: white; margin-bottom: 5px; }
        .news-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
        .news-card { background: white; border-radius: 12px; overflow: hidden; text-decoration: none; color: #333; }
        .news-card img { width: 100%; height: 180px; object-fit: cover; }
        .card-content { padding: 12px; }
        .section-title { font-size: 18px; font-weight: 800; color: var(--warna-biru); margin: 20px 0; border-left: 4px solid var(--warna-merah); padding-left: 10px; }
        .trending-list { background: white; border-radius: 12px; padding: 12px; margin-bottom: 12px; }
        .trending-item { display: flex; gap: 10px; padding: 10px; border-bottom: 1px solid #eee; text-decoration: none; color: #333; }
        .carousel-scroll { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 10px; }
        .carousel-item { flex: 0 0 80%; background: white; border-radius: 12px; padding: 10px; display: flex; gap: 10px; text-decoration: none; color: #333; }
        .carousel-item img { width: 100px; height: 80px; object-fit: cover; border-radius: 8px; }
        .ad-slot { text-align: center; margin: 20px 0; }
    </style>
</head>
<body>

    <div class="header-container">
        <div class="logo-bar">
            <div class="logo-text">PUL<span class="logo-new">NEW</span>.COM</div>
        </div>
    </div>

    <div class="container">
        <div id="news-container" style="text-align: center; padding: 40px;">Memuat berita...</div>
    </div>

    <script>
    const kategoriWarna = { 'NASIONAL': '#1B5E20', 'POLITIK': '#1B5E20', 'TEKNOLOGI': '#26C6DA', 'EKONOMI': '#D32f2f', 'BERITA': '#d32f2f' };

    async function ambilDataBerita() {
        try {
            const response = await fetch('posts.json?t=' + Date.now());
            const data = await response.json();
            if (data.posts) renderBerita(data.posts);
        } catch (err) {
            document.getElementById('news-container').innerHTML = "Gagal memuat berita.";
        }
    }

    function renderBerita(posts) {
        const container = document.getElementById('news-container');
        const getBadge = (p) => `<span class="badge" style="background:${kategoriWarna[p.kategori?.toUpperCase()] || '#d32f2f'}">${p.kategori || 'BERITA'}</span>`;
        
        let html = `
            <a href="/berita.html?slug=${posts[0].slug}" class="news-hero">
                <img src="${posts[0].image}" alt="${posts[0].title}">
                <div class="hero-content">${getBadge(posts[0])}<h2>${posts[0].title}</h2></div>
            </a>
        `;

        html += '<div class="news-grid">';
        posts.slice(1, 5).forEach(p => html += `<a href="/berita.html?slug=${p.slug}" class="news-card"><img src="${p.image}"><div class="card-content">${getBadge(p)}<h3>${p.title}</h3></div></a>`);
        html += '</div>';

        html += '<div class="ad-slot"><img src="/media/iklan_tengah1.png" alt="Iklan"></div>';

        if (posts.length > 5) {
            html += '<h3 class="section-title">🔥 Trending</h3><div class="trending-list">';
            posts.slice(5, 10).forEach((p, i) => html += `<a href="/berita.html?slug=${p.slug}" class="trending-item"><b>${i+1}</b><h4>${p.title}</h4></a>`);
            html += '</div>';
        }

        if (posts.length > 10) {
            html += '<h3 class="section-title">Berita Lain</h3><div class="carousel-scroll">';
            posts.slice(10, 30).forEach(p => html += `<a href="/berita.html?slug=${p.slug}" class="carousel-item"><img src="${p.image}"><div>${getBadge(p)}<h4>${p.title}</h4></div></a>`);
            html += '</div>';
        }

        container.innerHTML = html;
    }

    ambilDataBerita();
    </script>
</body>
</html>
