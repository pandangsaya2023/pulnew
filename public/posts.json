<script>
async function loadPost(){
  try {
    const res = await fetch('/posts.json');
    console.log('Status fetch posts.json:', res.status);
    
    if(!res.ok) throw new Error('Fetch gagal: ' + res.status);
    
    const posts = await res.json();
    console.log('Data posts:', posts);
    
    const slug = window.location.pathname.split('/').pop();
    console.log('Slug dari URL:', slug);
    
    const post = posts.find(p => p.slug === slug);
    console.log('Post ketemu:', post);
    
    if(!post){
      document.getElementById('content').innerHTML = '<div>Post tidak ditemukan</div>';
      return;
    }

    document.title = post.title + ' - PULNEW.com';
    document.getElementById('content').innerHTML = `
      <div class="article">
        <img src="/${post.image}" alt="${post.title}">
        <h1>${post.title}</h1>
        <div class="meta">${post.date} • ${post.category}</div>
        <div class="content">${post.content || 'Isi berita belum diisi'}</div>
      </div>
    `;
    
  } catch(e) {
    console.error('Error:', e);
    document.getElementById('content').innerHTML = '<div>Error load data: ' + e.message + '</div>';
  }
}

loadPost();
</script>
