<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Berita Terbaru</title>
<style>
body { font-family: Arial, sans-serif; margin: 0; background: #f5f5f5; }
.container { max-width: 800px; margin: 20px auto; padding: 0 15px; }
h1 { text-align: center; color: #d32f2f; }
.card {
  background: white; margin-bottom: 15px; padding: 15px; 
  border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  display: flex; gap: 15px; text-decoration: none; color: black;
}
.card:hover { box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
.card img { width: 120px; height: 80px; object-fit: cover; border-radius: 5px; }
.card h3 { margin: 0 0 5px 0; font-size: 18px; }
.card .meta { color: #666; font-size: 13px; }
.loading { text-align: center; padding: 40px; color: #666; }
</style>
</head>
<body>
<div class="container">
  <h1>📰 Berita Terbaru</h1>
  <div id="list-berita" class="loading">Loading berita...</div>
</div>

<script>
async function loadBerita() {
  try {
    // Ambil daftar file dari index.json
    const res = await fetch('/posts/index.json?t=' + Date.now());
    if (!res.ok) throw new Error('index.json tidak ditemukan');
    
    const data = await res.json();
    const slugs = data.posts || [];
    
    // Balik urutan biar berita terbaru di atas
    slugs.reverse();
    
    if (slugs.length === 0) {
      document.getElementById('list-berita').innerHTML = 'Belum ada berita';
      return;
    }
    
    // Ambil data tiap berita
    const posts = await Promise.all(
      slugs.map(slug => 
        fetch(`/posts/${slug}.json?t=${Date.now()}`)
          .then(r => r.ok ? r.json() : null)
          .catch(() => null)
      )
    );
    
    // Filter yang gagal load
    const validPosts = posts.filter(p => p && p.title);
    
    // Render ke HTML
    document.getElementById('list-berita').innerHTML = validPosts.map(post => `
      <a href="/berita.html?slug=${post.slug || post.title.toLowerCase().replace(/\s+/g,'-')}" class="card">
        <img src="${post.image || ''}" onerror="this.style.display='none'">
        <div>
          <h3>${post.title}</h3>
          <div class="meta">${post.category || 'Umum'} • ${post.date || ''}</div>
          <p>${post.body ? post.body.split('\n')[0].substring(0, 100) + '...' : ''}</p>
        </div>
      </a>
    `).join('');
    
  } catch (e) {
    document.getElementById('list-berita').innerHTML = 'Gagal load berita';
    console.error(e);
  }
}

loadBerita();
</script>
</body>
</html>
